import java.util.Scanner;

public class ArrayDuaDimensiNilai {
    public static void main(String[] args) {
        
        Scanner input = new Scanner(System.in);

        int jumlahMahasiswa;
        int jumlahMataKuliah;

        System.out.print("Masukkan jumlah mahasiswa: ");
        jumlahMahasiswa = input.nextInt();

        System.out.print("Masukkan jumlah mata kuliah: ");
        jumlahMataKuliah = input.nextInt();

        int[][] nilai = new int[jumlahMahasiswa][jumlahMataKuliah];

        for (int i = 0; i < jumlahMahasiswa; i++) {
            System.out.println("Mahasiswa ke-" + (i + 1));
            for (int j = 0; j < jumlahMataKuliah; j++) {
                System.out.print("Nilai Mata Kuliah ke-" + (j + 1) + " : ");
                nilai[i][j] = input.nextInt();
            }
            System.out.println();
        }

        System.out.println("Matriks Nilai Mahasiswa:");
        for (int i = 0; i < jumlahMahasiswa; i++) {
            for (int j = 0; j < jumlahMataKuliah; j++) {
                System.out.print(nilai[i][j] + "\t");
            }
            System.out.println();
        }

        input.close();
    }
}


