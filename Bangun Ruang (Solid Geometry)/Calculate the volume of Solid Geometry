import java.util.Scanner;

public class SolidGeometry {
    public static void main(String[] args) {
        try (Scanner scanner = new Scanner(System.in)) {
        
            System.out.println("=== Calculate Volume of 3D Shapes ===");
            
            String choice;
            do {
                // Sphere
                System.out.print("Enter sphere radius: ");
                double sphereRadius = scanner.nextDouble();
                Sphere sphere = new Sphere(sphereRadius);
                System.out.println("Sphere Volume: " + sphere.calculateVolume());
                
                // Cylinder
                System.out.print("Enter cylinder radius: ");
                double cylinderRadius = scanner.nextDouble();
                System.out.print("Enter cylinder height: ");
                double cylinderHeight = scanner.nextDouble();
                Cylinder cylinder = new Cylinder(cylinderRadius, cylinderHeight);
                System.out.println("Cylinder Volume: " + cylinder.calculateVolume());
                
                // Cone
                System.out.print("Enter cone radius: ");
                double coneRadius = scanner.nextDouble();
                System.out.print("Enter cone height: ");
                double coneHeight = scanner.nextDouble();
                Cone cone = new Cone(coneRadius, coneHeight);
                System.out.println("Cone Volume: " + cone.calculateVolume());

                System.out.print("Do you want to calculate again? (yes/no): ");
                choice = scanner.next();
            } while (choice.equalsIgnoreCase("yes"));
            
            System.out.println("Thanks for calculating here, see u very soon!");
        }
    }
}

class Sphere {
    private final double radius;
    public Sphere(double radius) {
        this.radius = radius;
    }
    public double calculateVolume() {
        return (4.0 / 3.0) * Math.PI * Math.pow(radius, 3);
    }
}

class Cylinder {
    private final double radius;
    private final double height;
    public Cylinder(double radius, double height) {
        this.radius = radius;
        this.height = height;
    }
    public double calculateVolume() {
        return Math.PI * Math.pow(radius, 2) * height;
    }
}

class Cone {
    private final double radius;
    private final double height;
    public Cone(double radius, double height) {
        this.radius = radius;
        this.height = height;
    }
    public double calculateVolume() {
        return (1.0 / 3.0) * Math.PI * Math.pow(radius, 2) * height;
    }
}
